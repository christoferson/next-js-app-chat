# Copy to .env.local and fill in your values. .env.local is gitignored.

# AWS region used when a model has no per-model region override
AWS_REGION=us-east-1

# Local AWS credentials profile (SSO supported: run `aws sso login` first)
AWS_PROFILE=your-profile-name

# Default model selected in the UI (must exist in lib/models/registry.ts)
DEFAULT_MODEL_ID=global.anthropic.claude-sonnet-5

# Default system prompt shown in the settings panel
DEFAULT_SYSTEM_PROMPT=You are a helpful assistant.
